#!/bin/sh
# SmoothNAS Custom Installer
# Replaces the Debian installer. Runs as init (PID 1) from the initrd.
#
# Flow:
#   1. Set up environment (mount /proc, /sys, /dev)
#   1b. Partition tools are embedded in the initrd by build-iso.sh
#   2. Network configuration (DHCP with manual fallback)
#   3. Disk selection (whiptail checklist, multi-select for RAID-1)
#   4. Partition and format (single-disk LVM or RAID-1 + LVM)
#   5. Install base system (debootstrap)
#   6. Install packages (apt-get in chroot)
#   7. Configure system (hostname, user, services, GRUB)
#   8. Prompt to remove media, reboot
set -e

TARGET="/mnt/target"
DEBIAN_MIRROR="http://deb.debian.org/debian"
DEBIAN_SUITE="trixie"
HOSTNAME="smoothnas"

# ============================================================
# Utility functions
# ============================================================

msg() {
    echo ""
    echo "=== $1 ==="
    echo ""
}

die() {
    echo ""
    echo "FATAL: $1" >&2
    echo "Dropping to shell for debugging. Type 'reboot' to restart."
    exec /bin/sh
}

# Run a whiptail command and capture its result safely.
# Whiptail writes its result to stderr. Using fd swaps (3>&1 1>&2 2>&3)
# is fragile because shell trace output and other stderr noise
# contaminates the captured value. This helper redirects whiptail's
# stderr to a temp file instead.
# Usage: wt_result=$(run_whiptail --inputbox "Prompt" 10 60 "default")
run_whiptail() {
    local _wt_tmp="/tmp/.wt-result"
    whiptail "$@" 2>"$_wt_tmp" </dev/console >/dev/console || true
    cat "$_wt_tmp" 2>/dev/null
    rm -f "$_wt_tmp"
}

# Ensure device mapper is loaded and LVM device nodes exist.
# The d-i initrd lacks /dev/mapper/, udev LVM rules, and dmsetup.
# We must: load dm_mod, create /dev/mapper/, and let LVM activate.
activate_lvm() {
    # 1. Make sure dm_mod is loaded.
    if ! grep -q device-mapper /proc/devices 2>/dev/null; then
        echo "  Loading device mapper..."
        modprobe dm_mod 2>/dev/null || true
    fi
    if ! grep -q device-mapper /proc/devices 2>/dev/null; then
        local kver
        kver=$(uname -r)
        for path in \
            "/usr/lib/modules/${kver}/kernel/drivers/md/dm-mod.ko.xz" \
            "/lib/modules/${kver}/kernel/drivers/md/dm-mod.ko.xz" \
            "/usr/lib/modules/${kver}/kernel/drivers/md/dm-mod.ko"; do
            if [ -f "$path" ]; then
                echo "  insmod $path"
                insmod "$path" 2>/dev/null || true
                break
            fi
        done
    fi
    if ! grep -q device-mapper /proc/devices 2>/dev/null; then
        die "Cannot load dm_mod. LVM requires device mapper."
    fi
    echo "  Device mapper: loaded"

    # 2. Create /dev/mapper/ if missing. LVM needs this directory to
    #    place its control node and device symlinks. The d-i initrd
    #    does not create it.
    mkdir -p /dev/mapper

    # 3. Create /dev/mapper/control if missing. dm_mod registers
    #    major 10 minor 236 (misc device) but the node may not exist
    #    without udev.
    if [ ! -e /dev/mapper/control ]; then
        mknod /dev/mapper/control c 10 236 2>/dev/null || true
    fi

    # 4. Activate the VG. This creates /dev/dm-N block devices and
    #    (with --mknodes) the /dev/VG/LV symlinks.
    vgchange -ay smoothnas-vg
    vgscan --mknodes 2>/dev/null || true
    vgmknodes smoothnas-vg 2>/dev/null || true
    sleep 1

    # 5. If /dev/smoothnas-vg/root still doesn't exist, create nodes
    #    manually by reading LV device paths from lvs.
    if [ ! -e /dev/smoothnas-vg/root ]; then
        echo "  Symlinks missing, creating device nodes from lvs..."
        mkdir -p /dev/smoothnas-vg

        # lvs can report the kernel major:minor for each LV.
        # Format: "root 253:1" or similar.
        local lv_info
        lv_info=$(lvs --noheadings --nosuffix -o lv_name,lv_kernel_major,lv_kernel_minor smoothnas-vg 2>/dev/null)
        echo "$lv_info" | while read -r name maj min rest; do
            if [ -n "$name" ] && [ -n "$maj" ] && [ -n "$min" ]; then
                if [ ! -e "/dev/smoothnas-vg/$name" ]; then
                    echo "    mknod /dev/smoothnas-vg/$name b $maj $min"
                    mknod "/dev/smoothnas-vg/$name" b "$maj" "$min"
                fi
            fi
        done
    fi

    # 6. Final check.
    if [ ! -e /dev/smoothnas-vg/root ]; then
        echo "  DEBUG: /proc/devices:"
        grep device-mapper /proc/devices 2>/dev/null || echo "    device-mapper NOT FOUND"
        echo "  DEBUG: ls /dev/mapper/:"
        ls -la /dev/mapper/ 2>/dev/null || echo "    does not exist"
        echo "  DEBUG: ls /dev/dm-*:"
        ls -la /dev/dm-* 2>/dev/null || echo "    no dm devices"
        echo "  DEBUG: ls /dev/smoothnas-vg/:"
        ls -la /dev/smoothnas-vg/ 2>/dev/null || echo "    does not exist"
        echo "  DEBUG: lvs output:"
        lvs -a -o +devices 2>/dev/null || echo "    lvs failed"
        echo "  DEBUG: lvm version:"
        lvm version 2>/dev/null || echo "    unknown"
        die "/dev/smoothnas-vg/root does not exist after all activation attempts"
    fi
    echo "  LVM devices: ready"
}

# ============================================================
# 1. Environment setup
# ============================================================

setup_env() {
    msg "Setting up environment"

    export PATH="/usr/sbin:/usr/bin:/sbin:/bin"

    # The d-i init has mounted /proc, /sys, /dev and started udev, but
    # early_command fires before storage/network udebs are loaded. We
    # inject all required modules into the initrd via build-iso.sh, so
    # load them here (busybox modprobe can't resolve deps from our
    # appended cpio layer, but works for modules already in the initrd).
    echo "  Loading modules..."
    # Storage and device-mapper.
    for mod in virtio_pci virtio_scsi virtio_blk sd_mod ahci nvme scsi_mod \
               dm_mod dm_linear dm_striped dm_snapshot; do
        modprobe "$mod" 2>/dev/null || true
    done
    # Filesystem modules (stock initrd, modprobe works).
    for mod in vfat fat nls_cp437 nls_ascii nls_utf8; do
        modprobe "$mod" 2>/dev/null || true
    done

    # Additional modules (injected by build-iso.sh, use insmod since busybox
    # modprobe can't resolve deps from our appended cpio layer).
    # Load dependencies first, then drivers.
    local kver
    kver=$(uname -r)
    local mbase="/usr/lib/modules/${kver}/kernel"
    # Device mapper (dm_mod): required for LVM device nodes.
    insmod "${mbase}/drivers/md/dm-mod.ko.xz" 2>/dev/null || true
    # ext4 and its dependencies (injected by build-iso.sh).
    # Try modprobe first (handles deps), fall back to manual insmod.
    if ! grep -q ext4 /proc/filesystems 2>/dev/null; then
        modprobe ext4 2>/dev/null || true
    fi
    if ! grep -q ext4 /proc/filesystems 2>/dev/null; then
        modprobe crc16 2>/dev/null || true
        modprobe crc32c_generic 2>/dev/null || true
        modprobe mbcache 2>/dev/null || true
        insmod "${mbase}/fs/jbd2/jbd2.ko.xz" 2>/dev/null || true
        insmod "${mbase}/fs/ext4/ext4.ko.xz" 2>/dev/null || true
    fi
    # Also search injected module dirs for ext4.
    if ! grep -q ext4 /proc/filesystems 2>/dev/null; then
        for ko in $(find /usr/lib/modules -name 'ext4.ko*' 2>/dev/null); do
            for dep in $(find /usr/lib/modules -name 'jbd2.ko*' 2>/dev/null); do
                insmod "$dep" 2>/dev/null || true
            done
            insmod "$ko" 2>/dev/null || true
        done
    fi
    if grep -q ext4 /proc/filesystems 2>/dev/null; then
        echo "  ext4 filesystem support: OK"
    else
        echo "  WARNING: ext4 not available, mount may fail"
    fi
    # Network: load failover first (virtio_net dependency), then virtio_net.
    insmod "${mbase}/net/core/failover.ko.xz" 2>/dev/null || true
    insmod "${mbase}/drivers/net/virtio_net.ko.xz" 2>/dev/null || true
    # Remaining network, PATA, RAID, multipath drivers.
    for dir in \
        "${mbase}/net/core" \
        "${mbase}/drivers/net" \
        "${mbase}/drivers/ata" \
        "${mbase}/drivers/md" \
        "${mbase}/drivers/scsi"; do
        for ko in $(find "$dir" -name '*.ko.xz' 2>/dev/null | sort); do
            insmod "$ko" 2>/dev/null || true
        done
    done

    udevadm trigger 2>/dev/null || true
    udevadm settle --timeout=10 2>/dev/null || sleep 3

    echo "  Block devices in /sys/block:"
    ls /sys/block/ 2>/dev/null || echo "    (empty)"
    echo "  Devices in /dev:"
    ls /dev/sd* /dev/nvme* /dev/vd* 2>/dev/null || echo "    (no disk devices)"
    echo "  Network interfaces:"
    ls /sys/class/net/ 2>/dev/null || echo "    (none)"
}
# ============================================================
# 2. Networking
# ============================================================

setup_network() {
    msg "Configuring network"

    # Collect all non-loopback network interfaces.
    local ifaces=""
    local iface_count=0
    for dev in /sys/class/net/*; do
        local name=$(basename "$dev")
        [ "$name" = "lo" ] && continue
        ifaces="$ifaces $name"
        iface_count=$((iface_count + 1))
    done
    ifaces=$(echo "$ifaces" | sed 's/^ //')

    if [ -z "$ifaces" ]; then
        die "No network interface found"
    fi

    echo "  Found $iface_count interface(s): $ifaces"

    # Bring all interfaces up in parallel.
    for iface in $ifaces; do
        ip link set "$iface" up &
    done
    wait
    sleep 1

    # Try DHCPv4 on all interfaces simultaneously.
    echo "  Trying DHCP on all interfaces..."
    local dhcp_tmpdir=$(mktemp -d)

    for iface in $ifaces; do
        (
            if command -v dhclient >/dev/null 2>&1; then
                dhclient -v "$iface" -timeout 15 2>/dev/null && touch "$dhcp_tmpdir/$iface"
            elif command -v udhcpc >/dev/null 2>&1; then
                udhcpc -i "$iface" -t 5 -n -q 2>/dev/null && touch "$dhcp_tmpdir/$iface"
            fi
        ) &
    done
    wait

    # Check which interfaces got an address.
    local got_ip=0
    for iface in $ifaces; do
        if [ -f "$dhcp_tmpdir/$iface" ]; then
            local ip_addr=$(ip -4 addr show "$iface" scope global | sed -n 's/.*inet \([0-9.]*\).*/\1/p' | head -1)
            echo "  DHCP succeeded on $iface: $ip_addr"
            got_ip=1
        fi
    done
    rm -rf "$dhcp_tmpdir"

    if [ "$got_ip" = "1" ]; then
        return
    fi

    # Try IPv6 SLAAC (already attempted in parallel via kernel).
    echo "  DHCPv4 failed on all interfaces. Checking IPv6 SLAAC..."
    sleep 3
    for iface in $ifaces; do
        local ip6_addr=$(ip -6 addr show "$iface" scope global | sed -n 's/.*inet6 \([0-9a-f:]*\).*/\1/p' | head -1)
        if [ -n "$ip6_addr" ]; then
            echo "  IPv6 address on $iface: $ip6_addr"
            return
        fi
    done

    # All interfaces failed DHCP. Fall back to manual configuration.
    # Use the first interface for the manual setup.
    local manual_iface=$(echo "$ifaces" | awk '{print $1}')
    ip link set "$manual_iface" up

    echo ""
    echo "  DHCP failed on all interfaces. Manual network configuration required."
    echo ""

    if command -v whiptail >/dev/null 2>&1; then
        local manual_ip=$(run_whiptail --title "Network Configuration" \
            --inputbox "DHCP failed on all interfaces.\n\nConfiguring $manual_iface manually.\n\nEnter IP address (CIDR notation, e.g. 192.168.1.100/24):" \
            12 60 "")

        if [ -z "$manual_ip" ]; then
            die "No IP address provided. Network is required for installation."
        fi

        local gateway=$(run_whiptail --title "Network Configuration" \
            --inputbox "Enter gateway IP:" \
            10 60 "")

        local dns=$(run_whiptail --title "Network Configuration" \
            --inputbox "Enter DNS server IP:" \
            10 60 "8.8.8.8")

        ip addr add "$manual_ip" dev "$manual_iface"
        [ -n "$gateway" ] && ip route add default via "$gateway"
        [ -n "$dns" ] && echo "nameserver $dns" > /etc/resolv.conf
    else
        echo "  Configuring $manual_iface manually."
        echo "  Enter IP address (CIDR, e.g. 192.168.1.100/24): "
        read manual_ip
        echo "  Enter gateway: "
        read gateway
        echo "  Enter DNS server [8.8.8.8]: "
        read dns
        dns=${dns:-8.8.8.8}

        ip addr add "$manual_ip" dev "$manual_iface"
        [ -n "$gateway" ] && ip route add default via "$gateway"
        echo "nameserver $dns" > /etc/resolv.conf
    fi

    echo "  Network configured on $manual_iface."
}

# ============================================================
# 2b. Sync system clock
# ============================================================

sync_clock() {
    msg "Syncing system clock"

    # The installer environment often has no RTC battery or NTP daemon,
    # so the clock may be wrong. Apt rejects repo signatures whose
    # "not before" timestamp is in the future relative to the local clock.

    # Try NTP first (busybox ntpd -q does a one-shot sync and exits).
    if command -v ntpd >/dev/null 2>&1; then
        echo "  Trying NTP sync..."
        if ntpd -dnqp pool.ntp.org 2>/dev/null; then
            echo "  Clock set via NTP: $(date -u)"
            return
        fi
        echo "  NTP failed, falling back to HTTP date..."
    fi

    # Fallback: fetch the Date header from the mirror via HTTP HEAD.
    # The mirror is plain HTTP so no TLS certificate date issues.
    local http_date=""
    http_date=$(wget -qS --spider "$DEBIAN_MIRROR/dists/$DEBIAN_SUITE/Release" 2>&1 \
        | sed -n 's/^ *Date: *//p' | head -1) || true

    if [ -z "$http_date" ]; then
        echo "  WARNING: Could not fetch date from mirror, clock may be wrong"
        return
    fi

    echo "  HTTP date: $http_date"

    # Busybox date -s cannot parse RFC 2822 format
    # (e.g. "Sat, 14 Mar 2026 11:25:23 UTC").
    # Convert to "YYYY-MM-DD HH:MM:SS" which busybox understands.
    local trimmed day month_name year time month
    trimmed=$(echo "$http_date" | sed 's/^[A-Za-z]*,[ ]*//')
    day=$(echo "$trimmed" | awk '{print $1}')
    month_name=$(echo "$trimmed" | awk '{print $2}')
    year=$(echo "$trimmed" | awk '{print $3}')
    time=$(echo "$trimmed" | awk '{print $4}')

    case "$month_name" in
        Jan) month="01" ;; Feb) month="02" ;; Mar) month="03" ;;
        Apr) month="04" ;; May) month="05" ;; Jun) month="06" ;;
        Jul) month="07" ;; Aug) month="08" ;; Sep) month="09" ;;
        Oct) month="10" ;; Nov) month="11" ;; Dec) month="12" ;;
        *)
            echo "  WARNING: Unrecognised month '$month_name', clock not set"
            return
            ;;
    esac

    # Zero-pad day.
    if [ ${#day} -eq 1 ]; then
        day="0$day"
    fi

    local iso_date="${year}-${month}-${day} ${time}"
    echo "  Setting clock to: $iso_date"

    if ! date -u -s "$iso_date" >/dev/null 2>&1; then
        echo "  WARNING: 'date -s' failed, clock may be wrong"
        return
    fi

    echo "  Clock set to: $(date -u)"
}

# ============================================================
# 3. Disk selection
# ============================================================

select_disks() {
    msg "Disk selection"

    # Discover physical disks.
    DISK_LIST=""
    DISK_COUNT=0

    # Collect disks with their sizes for sorting.
    local unsorted=""

    for dev in /sys/block/*; do
        local name=$(basename "$dev")

        case "$name" in
            loop*|ram*|sr*|dm-*|md*|nbd*|zram*) continue ;;
        esac

        local sz=$(cat "$dev/size" 2>/dev/null || echo 0)
        [ "$sz" -le 0 ] 2>/dev/null && continue

        local gb=$((sz * 512 / 1073741824))
        [ "$gb" -lt 1 ] && continue

        # Skip USB drives.
        local removable=$(cat "$dev/removable" 2>/dev/null || echo 0)
        if [ "$removable" = "1" ]; then
            continue
        fi
        # Also check the bus type via the device path.
        local devpath=$(readlink -f "$dev" 2>/dev/null || echo "")
        case "$devpath" in
            */usb*) continue ;;
        esac

        # Skip if any partition is mounted (likely the installer USB).
        local mounted=0
        for part in /dev/${name}*; do
            grep -q "^$part " /proc/mounts 2>/dev/null && mounted=1
        done
        [ "$mounted" = "1" ] && continue

        local model=$(cat "$dev/device/model" 2>/dev/null | sed 's/[[:space:]]*$//' | tr ' ' '_' || echo "Disk")
        [ -z "$model" ] && model="Disk"

        # Store as "size_sectors dev_entry" for sorting.
        unsorted="$unsorted
$sz /dev/$name ${gb}GB_${model} off"
    done

    # Sort by size (first field) ascending, then strip the sort key.
    local sorted=$(echo "$unsorted" | sort -n)
    local IFS_OLD="$IFS"
    IFS='
'
    for line in $sorted; do
        [ -z "$line" ] && continue
        # Strip leading size field.
        local entry=$(echo "$line" | sed 's/^[0-9]* //')
        DISK_LIST="$DISK_LIST $entry"
        DISK_COUNT=$((DISK_COUNT + 1))
    done
    IFS="$IFS_OLD"

    if [ "$DISK_COUNT" -eq 0 ]; then
        die "No available disks found"
    fi

    # Build parallel arrays from DISK_LIST for the text menu.
    # DISK_LIST format: "/dev/X sizeGB_model off /dev/Y ..."
    local disk_devs=""
    local disk_descs=""
    local disk_sel=""
    local i=0
    local _field=0
    for token in $DISK_LIST; do
        case "$_field" in
            0) disk_devs="$disk_devs $token"; _field=1 ;;
            1) disk_descs="$disk_descs $token"; _field=2 ;;
            2) disk_sel="$disk_sel 0"; _field=0; i=$((i + 1)) ;;
        esac
    done

    if command -v whiptail >/dev/null 2>&1; then
        SELECTED_DISKS=$(eval whiptail --title '"SmoothNAS - Select OS Disk(s)"' \
            --checklist '"Select one or more disks for the OS.\n\nOne disk: standard LVM install.\nTwo or more: RAID-1 mirror + LVM.\n\nRemaining disks will be managed by SmoothNAS."' \
            20 70 "$DISK_COUNT" \
            $DISK_LIST \
            3>&1 1>&2 2>&3) || true
        SELECTED_DISKS=$(echo "$SELECTED_DISKS" | tr -d '"')
    else
        # Text-based interactive disk selection.
        echo ""
        echo "  Select disk(s) for the OS install."
        echo "  One disk = standard LVM. Two or more = RAID-1 mirror + LVM."
        echo "  Remaining disks will be managed by SmoothNAS after install."
        echo ""

        while true; do
            echo "  Available disks:"
            local idx=1
            for dev in $disk_devs; do
                local desc=$(echo "$disk_descs" | awk "{print \$$idx}")
                local sel=$(echo "$disk_sel" | awk "{print \$$idx}")
                if [ "$sel" = "1" ]; then
                    echo "    $idx) [*] $dev  ($desc)"
                else
                    echo "    $idx) [ ] $dev  ($desc)"
                fi
                idx=$((idx + 1))
            done
            echo ""
            echo "  Enter a number to toggle, or 'done' to continue: "
            read choice

            if [ "$choice" = "done" ] || [ "$choice" = "d" ]; then
                break
            fi

            # Validate input is a number in range.
            if echo "$choice" | grep -q '^[0-9]*$' && [ "$choice" -ge 1 ] 2>/dev/null && [ "$choice" -le "$DISK_COUNT" ] 2>/dev/null; then
                # Toggle the selection.
                local new_sel=""
                local t=1
                for s in $disk_sel; do
                    if [ "$t" = "$choice" ]; then
                        if [ "$s" = "1" ]; then
                            new_sel="$new_sel 0"
                        else
                            new_sel="$new_sel 1"
                        fi
                    else
                        new_sel="$new_sel $s"
                    fi
                    t=$((t + 1))
                done
                disk_sel="$new_sel"
            else
                echo "  Invalid choice."
            fi
        done

        # Build SELECTED_DISKS from selections.
        SELECTED_DISKS=""
        local idx=1
        for dev in $disk_devs; do
            local sel=$(echo "$disk_sel" | awk "{print \$$idx}")
            if [ "$sel" = "1" ]; then
                SELECTED_DISKS="$SELECTED_DISKS $dev"
            fi
            idx=$((idx + 1))
        done
        SELECTED_DISKS=$(echo "$SELECTED_DISKS" | sed 's/^ *//')
    fi

    if [ -z "$SELECTED_DISKS" ]; then
        die "No disks selected"
    fi

    SELECTED_COUNT=$(echo "$SELECTED_DISKS" | wc -w)
    echo "  Selected $SELECTED_COUNT disk(s): $SELECTED_DISKS"

    if [ "$SELECTED_COUNT" -gt 1 ]; then
        USE_RAID=1
        echo "  Mode: RAID-1 + LVM"
    else
        USE_RAID=0
        echo "  Mode: Single disk + LVM"
    fi
}

# ============================================================
# 3b. Password prompt
# ============================================================

prompt_password() {
    msg "Set admin password"

    ADMIN_PASSWORD=""

    if command -v whiptail >/dev/null 2>&1; then
        while true; do
            local pass1=$(run_whiptail --title "SmoothNAS - Admin Password" \
                --passwordbox "Enter password for the 'admin' account (min 6 characters):" \
                10 60 "")

            if [ -z "$pass1" ]; then
                die "Password is required"
            fi

            if [ ${#pass1} -lt 6 ]; then
                whiptail --title "Error" --msgbox "Password must be at least 6 characters." 8 50
                continue
            fi

            local pass2=$(run_whiptail --title "SmoothNAS - Confirm Password" \
                --passwordbox "Confirm password:" \
                10 60 "")

            if [ "$pass1" != "$pass2" ]; then
                whiptail --title "Error" --msgbox "Passwords do not match." 8 50
                continue
            fi

            ADMIN_PASSWORD="$pass1"
            break
        done
    else
        while true; do
            echo -n "  Enter admin password (min 8 chars): "
            stty -echo
            read pass1
            stty echo
            echo ""

            if [ ${#pass1} -lt 6 ]; then
                echo "  Password must be at least 6 characters."
                continue
            fi

            echo -n "  Confirm password: "
            stty -echo
            read pass2
            stty echo
            echo ""

            if [ "$pass1" != "$pass2" ]; then
                echo "  Passwords do not match."
                continue
            fi

            ADMIN_PASSWORD="$pass1"
            break
        done
    fi

    echo "  Password set."
}

# ============================================================
# 4. Partitioning
# ============================================================

wipe_disk() {
    local disk="$1"
    echo "  Wiping $disk..."

    # Stop any active RAID arrays using partitions on this disk.
    for md in /dev/md*; do
        [ -b "$md" ] || continue
        mdadm --stop "$md" 2>/dev/null || true
    done

    # Deactivate any LVM volume groups that use this disk.
    for pv in $(pvs --noheadings -o pv_name 2>/dev/null | grep "$disk" || true); do
        local vg=$(pvs --noheadings -o vg_name "$pv" 2>/dev/null | tr -d ' ')
        [ -n "$vg" ] && vgchange -an "$vg" 2>/dev/null || true
        [ -n "$vg" ] && vgremove -ff "$vg" 2>/dev/null || true
        pvremove -ff "$pv" 2>/dev/null || true
    done

    # Remove partition signatures and metadata.
    for part in "${disk}"[0-9]* "${disk}p"[0-9]*; do
        [ -b "$part" ] || continue
        wipefs -a "$part" 2>/dev/null || true
        mdadm --zero-superblock "$part" 2>/dev/null || true
    done

    # Wipe the disk itself: signatures, first 10MB, and last 10MB.
    # This catches GPT headers (start+end), MBR, mdadm superblocks
    # (stored at end of device), and LVM labels.
    wipefs -a "$disk" 2>/dev/null || true
    mdadm --zero-superblock "$disk" 2>/dev/null || true
    dd if=/dev/zero of="$disk" bs=1M count=10 2>/dev/null || true
    local disk_size=$(blockdev --getsize64 "$disk" 2>/dev/null || echo 0)
    if [ "$disk_size" -gt 10485760 ]; then
        dd if=/dev/zero of="$disk" bs=1M count=10 \
            seek=$(( (disk_size / 1048576) - 10 )) 2>/dev/null || true
    fi

    # Destroy all GPT and MBR structures so sgdisk starts clean.
    # Without this, corrupt/mismatched GPT headers cause sgdisk to
    # prompt interactively or hang during partitioning.
    sgdisk --zap-all "$disk" 2>/dev/null || true

    # Force kernel to re-read partition table.
    partprobe "$disk" 2>/dev/null || true
    sleep 1
}

do_partitioning() {
    msg "Partitioning"

    mkdir -p "$TARGET"

    # Stop ALL active RAID arrays and LVM first, regardless of which disks
    # they're on. Stale metadata on non-selected disks can cause arrays
    # to auto-assemble with wrong membership.
    echo "  Stopping all active RAID arrays and LVM..."
    vgchange -an 2>/dev/null || true
    for md in /dev/md*; do
        [ -b "$md" ] || continue
        mdadm --stop "$md" 2>/dev/null || true
    done
    # Zero RAID superblocks on ALL disk partitions system-wide.
    for dev in /dev/sd*[0-9] /dev/nvme*p[0-9]*; do
        [ -b "$dev" ] || continue
        mdadm --zero-superblock "$dev" 2>/dev/null || true
    done

    # Thoroughly wipe all selected disks to remove leftover GPT/LVM/RAID
    # metadata that could interfere with the fresh install.
    for disk in $SELECTED_DISKS; do
        wipe_disk "$disk"
    done

    if [ "$USE_RAID" = "1" ]; then
        partition_raid
    else
        partition_single
    fi
}

partition_single() {
    local disk=$(echo "$SELECTED_DISKS" | awk '{print $1}')
    echo "  Partitioning $disk (single disk + LVM)..."

    # Create GPT partitions using sgdisk:
    # 1: BIOS Boot (1MB, required for GRUB on GPT)
    # 2: EFI System Partition (512MB)
    # 3: /boot (1GB)
    # 4: LVM (rest)
    sgdisk -n 1:0:+1M -t 1:ef02 -c 1:"bios-boot" "$disk"
    sgdisk -n 2:0:+512M -t 2:ef00 -c 2:"EFI" "$disk"
    sgdisk -n 3:0:+1G -t 3:8300 -c 3:"boot" "$disk"
    sgdisk -n 4:0:0 -t 4:8e00 -c 4:"lvm" "$disk"

    sleep 1
    blockdev --rereadpt "$disk" 2>/dev/null || true
    sleep 1

    # Determine partition names (nvme uses p1, sata uses 1).
    local p1 p2 p3 p4
    if echo "$disk" | grep -q "nvme"; then
        p1="${disk}p1"; p2="${disk}p2"; p3="${disk}p3"; p4="${disk}p4"
    else
        p1="${disk}1"; p2="${disk}2"; p3="${disk}3"; p4="${disk}4"
    fi

    # Format (p1 is BIOS boot, no filesystem needed).
    mkfs.vfat -F 32 "$p2"
    mkfs.ext4 -F "$p3"

    # LVM -- clean up any previous install first.
    vgremove -ff smoothnas-vg 2>/dev/null || true
    pvremove -ff "$p4" 2>/dev/null || true
    pvcreate -ff -y "$p4"
    vgcreate smoothnas-vg "$p4"
    lvcreate -Wy -y -L 4G -n swap smoothnas-vg
    lvcreate -Wy -y -l 100%FREE -n root smoothnas-vg

    # Ensure LVM device nodes exist.
    vgscan --mknodes 2>/dev/null || true
    vgchange -ay smoothnas-vg 2>/dev/null || true
    udevadm settle --timeout=5 2>/dev/null || sleep 2

    mkswap /dev/smoothnas-vg/swap
    mkfs.ext4 -F /dev/smoothnas-vg/root

    # Mount.
    mount -t ext4 /dev/smoothnas-vg/root "$TARGET" || \
        die "Failed to mount /dev/smoothnas-vg/root on $TARGET"
    mkdir -p "$TARGET/boot"
    mount "$p3" "$TARGET/boot"
    mkdir -p "$TARGET/boot/efi"
    mount -t vfat "$p2" "$TARGET/boot/efi"

    GRUB_DISK="$disk"
}

partition_raid() {
    echo "  Partitioning for RAID-1 + LVM..."

    local disk_num=0
    local boot_parts=""
    local raid_parts=""

    for disk in $SELECTED_DISKS; do
        echo "    Partitioning $disk..."

        # 1: BIOS Boot (1MB, required for GRUB on GPT)
        # 2: EFI (only used on first disk, but create on all for consistency)
        # 3: /boot RAID partition (1GB)
        # 4: LVM RAID partition (rest)
        sgdisk -n 1:0:+1M -t 1:ef02 -c 1:"bios-boot" "$disk"
        sgdisk -n 2:0:+512M -t 2:ef00 -c 2:"EFI" "$disk"
        sgdisk -n 3:0:+1G -t 3:fd00 -c 3:"boot-raid" "$disk"
        sgdisk -n 4:0:0 -t 4:fd00 -c 4:"lvm-raid" "$disk"

        sleep 1
        blockdev --rereadpt "$disk" 2>/dev/null || true
        sleep 1

        local p3 p4
        if echo "$disk" | grep -q "nvme"; then
            p3="${disk}p3"; p4="${disk}p4"
        else
            p3="${disk}3"; p4="${disk}4"
        fi

        boot_parts="$boot_parts $p3"
        raid_parts="$raid_parts $p4"
        disk_num=$((disk_num + 1))
    done

    # Create RAID arrays.
    echo "    Creating RAID-1 arrays..."
    mdadm --create /dev/md0 --level=1 --raid-devices=$disk_num \
        --metadata=1.2 --run $boot_parts <<EOF
yes
EOF
    mdadm --create /dev/md1 --level=1 --raid-devices=$disk_num \
        --metadata=1.2 --run $raid_parts <<EOF
yes
EOF

    sleep 2

    # Format /boot on md0.
    mkfs.ext4 -F /dev/md0

    # LVM on md1 -- clean up any previous install first.
    vgremove -ff smoothnas-vg 2>/dev/null || true
    pvremove -ff /dev/md1 2>/dev/null || true
    pvcreate -ff -y /dev/md1
    vgcreate smoothnas-vg /dev/md1
    lvcreate -Wy -y -L 4G -n swap smoothnas-vg
    lvcreate -Wy -y -l 100%FREE -n root smoothnas-vg

    # Ensure LVM device nodes exist.
    vgscan --mknodes 2>/dev/null || true
    vgchange -ay smoothnas-vg 2>/dev/null || true
    udevadm settle --timeout=5 2>/dev/null || sleep 2

    mkswap /dev/smoothnas-vg/swap
    mkfs.ext4 -F /dev/smoothnas-vg/root

    # EFI on first disk only (partition 2, after BIOS boot).
    local first_disk=$(echo "$SELECTED_DISKS" | awk '{print $1}')
    local efi_part
    if echo "$first_disk" | grep -q "nvme"; then
        efi_part="${first_disk}p2"
    else
        efi_part="${first_disk}2"
    fi
    mkfs.vfat -F 32 "$efi_part"

    # Mount.
    mount -t ext4 /dev/smoothnas-vg/root "$TARGET" || \
        die "Failed to mount /dev/smoothnas-vg/root on $TARGET"
    mkdir -p "$TARGET/boot"
    mount /dev/md0 "$TARGET/boot"
    mkdir -p "$TARGET/boot/efi"
    mount -t vfat "$efi_part" "$TARGET/boot/efi"

    GRUB_DISK="$first_disk"
}

# ============================================================
# 5. Install base system
# ============================================================

install_base() {
    msg "Installing base system (this may take several minutes)"

    # debootstrap and pkgdetails are bundled into the initrd by build-iso.sh.
    if ! command -v debootstrap >/dev/null 2>&1; then
        die "debootstrap not found in initrd -- rebuild ISO with build-iso.sh"
    fi

    echo "  Running debootstrap for ${DEBIAN_SUITE}..."
    # Use --foreign to run first stage only (download + extract, no
    # configure). Then set up debconf for noninteractive mode inside the
    # target before running the second stage (configure). Without this,
    # libpam-runtime's postinst hangs because debconf falls back to a
    # terminal-reading frontend inside the chroot.
    debootstrap --foreign --arch=amd64 \
        "$DEBIAN_SUITE" "$TARGET" "$DEBIAN_MIRROR" || \
        die "debootstrap first stage failed"

    # Stub out libpam-runtime's postinst during debootstrap to prevent
    # it from hanging. Its postinst sources debconf confmodule which execs
    # a Perl frontend that blocks in debootstrap's minimal chroot.
    #
    # Strategy: dpkg pre-invoke hook that replaces the postinst with a
    # no-op before dpkg --configure runs it. The hook fires between
    # dpkg --unpack (creates postinst) and dpkg --configure (runs it).
    mkdir -p "$TARGET/etc/dpkg/dpkg.cfg.d"
    cat > "$TARGET/etc/dpkg/dpkg.cfg.d/smoothnas-bootstrap" << 'DPKGCFG'
pre-invoke=/debootstrap/stub-pam-postinst
DPKGCFG
    cat > "$TARGET/debootstrap/stub-pam-postinst" << 'HOOK'
#!/bin/sh
# Stub any postinst that sources debconf confmodule, which would exec
# a Perl frontend that hangs in debootstrap's minimal chroot.
for f in /var/lib/dpkg/info/*.postinst; do
    [ -f "$f" ] || continue
    grep -q SMOOTHNAS_STUB "$f" 2>/dev/null && continue
    grep -q '/usr/share/debconf/confmodule' "$f" 2>/dev/null || continue
    cp "$f" "${f}.real"
    printf '#!/bin/sh\n# SMOOTHNAS_STUB\nexit 0\n' > "$f"
    chmod +x "$f"
done
HOOK
    chmod +x "$TARGET/debootstrap/stub-pam-postinst"

    echo "  Running debootstrap second stage..."
    DEBIAN_FRONTEND=noninteractive chroot "$TARGET" \
        /debootstrap/debootstrap --second-stage || \
        die "debootstrap second stage failed"

    # Clean up dpkg hook.
    rm -f "$TARGET/etc/dpkg/dpkg.cfg.d/smoothnas-bootstrap"
    rm -f "$TARGET/debootstrap/stub-pam-postinst"

    # Restore all stubbed postinsts and reconfigure those packages.
    local stubbed_pkgs=""
    for real in "$TARGET"/var/lib/dpkg/info/*.postinst.real; do
        [ -f "$real" ] || continue
        local base="${real%.real}"
        mv "$real" "$base"
        local pkg=$(basename "$base" .postinst)
        stubbed_pkgs="$stubbed_pkgs $pkg"
    done

    if [ -n "$stubbed_pkgs" ]; then
        echo "  Reconfiguring stubbed packages:$stubbed_pkgs"
        mount --bind /dev "$TARGET/dev" 2>/dev/null || true
        mount --bind /dev/pts "$TARGET/dev/pts" 2>/dev/null || true
        mount -t proc proc "$TARGET/proc" 2>/dev/null || true
        mount -t sysfs sysfs "$TARGET/sys" 2>/dev/null || true
        for pkg in $stubbed_pkgs; do
            echo "    Configuring $pkg..."
            DEBIAN_FRONTEND=noninteractive chroot "$TARGET" \
                dpkg --configure "$pkg" 2>&1 || \
                echo "    WARNING: $pkg configure returned non-zero"
        done
        umount "$TARGET/sys" 2>/dev/null || true
        umount "$TARGET/proc" 2>/dev/null || true
        umount "$TARGET/dev/pts" 2>/dev/null || true
        umount "$TARGET/dev" 2>/dev/null || true
    fi

    echo "  Base system installed."
}

# ============================================================
# 6. Install packages
# ============================================================

install_packages() {
    msg "Installing packages"

    # Mount virtual filesystems for chroot.
    mount --bind /dev "$TARGET/dev"
    mount --bind /dev/pts "$TARGET/dev/pts"
    mount -t proc proc "$TARGET/proc"
    mount -t sysfs sysfs "$TARGET/sys"

    # Configure apt sources with contrib.
    cat > "$TARGET/etc/apt/sources.list" << SOURCES
deb $DEBIAN_MIRROR $DEBIAN_SUITE main contrib non-free-firmware
deb $DEBIAN_MIRROR ${DEBIAN_SUITE}-updates main contrib non-free-firmware
deb http://security.debian.org/debian-security ${DEBIAN_SUITE}-security main contrib non-free-firmware
SOURCES

    # Prevent services from starting during install.
    cat > "$TARGET/usr/sbin/policy-rc.d" << 'POLICY'
#!/bin/sh
exit 101
POLICY
    chmod +x "$TARGET/usr/sbin/policy-rc.d"

    # Force noninteractive debconf inside the chroot. Three layers of defense:
    # 1. Set debconf frontend via debconf-set-selections
    # 2. Disable dpkg-preconfigure (which spawns debconf and can hang)
    # 3. DEBIAN_FRONTEND env var on every chroot call
    echo "debconf debconf/frontend select Noninteractive" | \
        chroot "$TARGET" debconf-set-selections 2>/dev/null || true
    # Replace dpkg-preconfigure with a no-op to prevent apt from hanging.
    if [ -f "$TARGET/usr/sbin/dpkg-preconfigure" ]; then
        mv "$TARGET/usr/sbin/dpkg-preconfigure" "$TARGET/usr/sbin/dpkg-preconfigure.real"
        printf '#!/bin/sh\nexit 0\n' > "$TARGET/usr/sbin/dpkg-preconfigure"
        chmod +x "$TARGET/usr/sbin/dpkg-preconfigure"
    fi
    # Install the same dpkg hook used during debootstrap: stub any postinst
    # that sources debconf confmodule, since the Perl debconf frontend hangs
    # in this installer environment. Also stub programs that use debconf
    # internally (pam-auth-update, update-ca-certificates).
    mkdir -p "$TARGET/etc/dpkg/dpkg.cfg.d"
    cat > "$TARGET/etc/dpkg/dpkg.cfg.d/smoothnas-install" << 'DPKGCFG'
pre-invoke=/tmp/smoothnas-stub-debconf
DPKGCFG
    cat > "$TARGET/tmp/smoothnas-stub-debconf" << 'HOOK'
#!/bin/sh
for f in /var/lib/dpkg/info/*.postinst; do
    [ -f "$f" ] || continue
    grep -q SMOOTHNAS_STUB "$f" 2>/dev/null && continue
    grep -q '/usr/share/debconf/confmodule' "$f" 2>/dev/null || continue
    cp "$f" "${f}.real"
    printf '#!/bin/sh\n# SMOOTHNAS_STUB\nexit 0\n' > "$f"
    chmod +x "$f"
done
HOOK
    chmod +x "$TARGET/tmp/smoothnas-stub-debconf"
    # Stub pam-auth-update (called by libpam-systemd, openssh-server, etc.)
    if [ -f "$TARGET/usr/sbin/pam-auth-update" ]; then
        mv "$TARGET/usr/sbin/pam-auth-update" "$TARGET/usr/sbin/pam-auth-update.real"
        printf '#!/bin/sh\nexit 0\n' > "$TARGET/usr/sbin/pam-auth-update"
        chmod +x "$TARGET/usr/sbin/pam-auth-update"
    fi

    chroot "$TARGET" apt-get update -qq

    # Note: || true on apt-get calls because postinst stubs cause expected
    # configuration errors. Packages are reconfigured properly at cleanup.
    # GRUB packages are critical and must not fail silently.
    echo "  Installing bootloader packages..."
    DEBIAN_FRONTEND=noninteractive chroot "$TARGET" apt-get install -y \
        grub-efi-amd64 grub-pc-bin efibootmgr \
        2>&1 || die "Failed to install GRUB packages"

    echo "  Installing kernel and core packages..."
    DEBIAN_FRONTEND=noninteractive chroot "$TARGET" apt-get install -y -qq \
        linux-image-amd64 linux-headers-amd64 \
        lvm2 mdadm \
        openssh-server \
        sudo curl wget ca-certificates \
        systemd-timesyncd systemd-resolved \
        2>/dev/null || true

    echo "  Installing storage packages..."
    DEBIAN_FRONTEND=noninteractive chroot "$TARGET" apt-get install -y \
        zfs-dkms zfsutils-linux \
        2>&1 || die "Failed to install ZFS packages"
    # Ensure ZFS module loads on every boot.
    grep -qxF 'zfs' "$TARGET/etc/modules" 2>/dev/null || echo 'zfs' >> "$TARGET/etc/modules"
    # BBR TCP congestion control (built as a module in Debian's kernel).
    grep -qxF 'tcp_bbr' "$TARGET/etc/modules" 2>/dev/null || echo 'tcp_bbr' >> "$TARGET/etc/modules"

    DEBIAN_FRONTEND=noninteractive chroot "$TARGET" apt-get install -y -qq \
        thin-provisioning-tools \
        smartmontools hdparm nvme-cli \
        gdisk \
        fio \
        psmisc \
        2>/dev/null || true

    echo "  Installing network test packages..."
    DEBIAN_FRONTEND=noninteractive chroot "$TARGET" apt-get install -y -qq \
        iperf3 \
        2>/dev/null || true
    chroot "$TARGET" bash -lc 'curl -fsSL https://packagecloud.io/install/repositories/ookla/speedtest-cli/script.deb.sh | bash' \
        2>/dev/null || true
    DEBIAN_FRONTEND=noninteractive chroot "$TARGET" apt-get install -y -qq \
        speedtest \
        2>/dev/null || true

    echo "  Installing service packages..."
    DEBIAN_FRONTEND=noninteractive chroot "$TARGET" apt-get install -y -qq \
        nginx nftables \
        samba cifs-utils \
        nfs-kernel-server \
        targetcli-fb python3-rtslib-fb \
        2>/dev/null || true

    # Remove dpkg hook and restore stubbed binaries.
    rm -f "$TARGET/etc/dpkg/dpkg.cfg.d/smoothnas-install"
    rm -f "$TARGET/tmp/smoothnas-stub-debconf"
    if [ -f "$TARGET/usr/sbin/dpkg-preconfigure.real" ]; then
        mv "$TARGET/usr/sbin/dpkg-preconfigure.real" "$TARGET/usr/sbin/dpkg-preconfigure"
    fi
    if [ -f "$TARGET/usr/sbin/pam-auth-update.real" ]; then
        mv "$TARGET/usr/sbin/pam-auth-update.real" "$TARGET/usr/sbin/pam-auth-update"
    fi

    # Restore all stubbed postinsts.
    for real in "$TARGET"/var/lib/dpkg/info/*.postinst.real; do
        [ -f "$real" ] || continue
        mv "$real" "${real%.real}"
    done

    # The ca-certificates postinst was stubbed above, so neither its debconf
    # config file nor the CA bundle were generated during package installation.
    # Regenerate both so that TLS connections work on first boot.
    chroot "$TARGET" sh -c '
        find /usr/share/ca-certificates -name "*.crt" -printf "%P\n" | sort > /etc/ca-certificates.conf
        update-ca-certificates --fresh
    ' 2>/dev/null || true

    # Generate PAM config files directly instead of running pam-auth-update,
    # which hangs because it uses debconf's Perl frontend.
    echo "  Generating PAM configuration..."
    cat > "$TARGET/etc/pam.d/common-auth" << 'PAM'
# /etc/pam.d/common-auth - generated by SmoothNAS installer
auth	[success=1 default=ignore]	pam_unix.so nullok
auth	requisite			pam_deny.so
auth	required			pam_permit.so
PAM
    cat > "$TARGET/etc/pam.d/common-account" << 'PAM'
# /etc/pam.d/common-account - generated by SmoothNAS installer
account	[success=1 new_authtok_reqd=done default=ignore]	pam_unix.so
account	requisite			pam_deny.so
account	required			pam_permit.so
PAM
    cat > "$TARGET/etc/pam.d/common-session" << 'PAM'
# /etc/pam.d/common-session - generated by SmoothNAS installer
session	[default=1]			pam_permit.so
session	requisite			pam_deny.so
session	required			pam_permit.so
session	required	pam_unix.so
PAM
    cat > "$TARGET/etc/pam.d/common-session-noninteractive" << 'PAM'
# /etc/pam.d/common-session-noninteractive - generated by SmoothNAS installer
session	[default=1]			pam_permit.so
session	requisite			pam_deny.so
session	required			pam_permit.so
session	required	pam_unix.so
PAM
    cat > "$TARGET/etc/pam.d/common-password" << 'PAM'
# /etc/pam.d/common-password - generated by SmoothNAS installer
password	[success=1 default=ignore]	pam_unix.so obscure yescrypt
password	requisite			pam_deny.so
password	required			pam_permit.so
PAM

    # Dedicated PAM service for tierd. Uses pam_unix directly so that web
    # UI login works even if pam-auth-update corrupts the common-* files
    # during firstboot's deferred dpkg --configure.  The "login" PAM service
    # is inappropriate for a daemon (it pulls in pam_nologin, pam_securetty,
    # etc. that assume an interactive terminal).
    cat > "$TARGET/etc/pam.d/tierd" << 'PAM'
# PAM service for tierd web UI authentication.
auth	[success=1 default=ignore]	pam_unix.so nullok
auth	requisite			pam_deny.so
auth	required			pam_permit.so
account	[success=1 new_authtok_reqd=done default=ignore]	pam_unix.so
account	requisite			pam_deny.so
account	required			pam_permit.so
PAM

    # Do NOT reconfigure packages here. The debconf Perl frontend hangs
    # in this installer environment. Deferred to firstboot where a proper
    # init, terminal, and debconf are available.
    echo "  Package reconfiguration deferred to first boot."

    rm -f "$TARGET/usr/sbin/policy-rc.d"
    chroot "$TARGET" apt-get clean -qq

    echo "  All packages installed."
}

# ============================================================
# 7. Configure system
# ============================================================

configure_system() {
    msg "Configuring system"

    # Login banner with IP and instructions.
    cat > "$TARGET/etc/issue" << 'ISSUE'

  SmoothNAS  -  \n
  IP: \4
  Web UI: https://\4
  Log in as admin with the password you set during install.

ISSUE

    # Hostname.
    echo "$HOSTNAME" > "$TARGET/etc/hostname"
    cat > "$TARGET/etc/hosts" << HOSTS
127.0.0.1 localhost
127.0.1.1 $HOSTNAME

::1 localhost ip6-localhost ip6-loopback
HOSTS

    # Timezone.
    chroot "$TARGET" ln -sf /usr/share/zoneinfo/UTC /etc/localtime

    # fstab -- use UUIDs for /boot and /boot/efi so device path changes
    # between install and first boot don't cause mount failures (which
    # would drop the system into emergency mode).
    local boot_dev boot_uuid efi_dev efi_uuid
    if [ "$USE_RAID" = "1" ]; then
        boot_dev="/dev/md0"
    else
        local disk=$(echo "$SELECTED_DISKS" | awk '{print $1}')
        if echo "$disk" | grep -q "nvme"; then boot_dev="${disk}p3"; else boot_dev="${disk}3"; fi
    fi
    local first_disk=$(echo "$SELECTED_DISKS" | awk '{print $1}')
    if echo "$first_disk" | grep -q "nvme"; then
        efi_dev="${first_disk}p2"
    else
        efi_dev="${first_disk}2"
    fi

    boot_uuid=$(blkid -s UUID -o value "$boot_dev" 2>/dev/null || true)
    efi_uuid=$(blkid -s UUID -o value "$efi_dev" 2>/dev/null || true)

    cat > "$TARGET/etc/fstab" << FSTAB
# <file system>          <mount point> <type> <options>       <dump> <pass>
/dev/smoothnas-vg/root   /             ext4   errors=remount-ro 0    1
/dev/smoothnas-vg/swap   none          swap   sw              0      0
FSTAB

    if [ -n "$boot_uuid" ]; then
        echo "UUID=${boot_uuid}        /boot         ext4   defaults        0      2" >> "$TARGET/etc/fstab"
    else
        echo "${boot_dev}              /boot         ext4   defaults        0      2" >> "$TARGET/etc/fstab"
    fi

    if [ -n "$efi_uuid" ]; then
        echo "UUID=${efi_uuid}         /boot/efi     vfat   umask=0077,nofail      0      1" >> "$TARGET/etc/fstab"
    else
        echo "${efi_dev}               /boot/efi     vfat   umask=0077,nofail      0      1" >> "$TARGET/etc/fstab"
    fi

    # Create tierd group and admin user with the password set during prompts.
    chroot "$TARGET" groupadd --system tierd 2>/dev/null || true
    # Ensure sudo group exists (should be in base-passwd, but be defensive).
    chroot "$TARGET" groupadd --system sudo 2>/dev/null || true
    if ! chroot "$TARGET" useradd --create-home --groups tierd,sudo --shell /bin/bash admin; then
        # If admin already exists (e.g. re-install), just update groups/shell.
        chroot "$TARGET" usermod --groups tierd,sudo --shell /bin/bash admin || \
            die "Failed to create or configure admin user"
    fi
    echo "admin:${ADMIN_PASSWORD}" | chroot "$TARGET" chpasswd
    # Set root to the admin password for now; firstboot will randomise it.
    echo "root:${ADMIN_PASSWORD}" | chroot "$TARGET" chpasswd

    # Save credentials.
    mkdir -p "$TARGET/var/lib/tierd"
    cat > "$TARGET/var/lib/tierd/initial-credentials" << CREDS
SmoothNAS Initial Credentials

Username: admin

Delete this file after changing the password.
CREDS
    chmod 600 "$TARGET/var/lib/tierd/initial-credentials"

    # Generate TLS certificate.
    mkdir -p "$TARGET/etc/tierd/tls"
    chroot "$TARGET" openssl req -x509 -nodes -days 3650 \
        -newkey rsa:2048 \
        -keyout /etc/tierd/tls/key.pem \
        -out /etc/tierd/tls/cert.pem \
        -subj "/CN=${HOSTNAME}/O=SmoothNAS" \
        -addext "subjectAltName=DNS:${HOSTNAME},DNS:localhost,IP:127.0.0.1" \
        2>/dev/null
    chmod 600 "$TARGET/etc/tierd/tls/key.pem"

    # Disable sharing services by default (tierd enables on demand).
    chroot "$TARGET" systemctl disable smbd nmbd 2>/dev/null || true
    chroot "$TARGET" systemctl disable nfs-kernel-server 2>/dev/null || true
    chroot "$TARGET" systemctl disable rtslib-fb-targetctl 2>/dev/null || true

    # Create empty targetcli config.
    mkdir -p "$TARGET/etc/target"
    echo '{"fabric_modules": [], "storage_objects": [], "targets": []}' > "$TARGET/etc/target/saveconfig.json"

    # Disable ifupdown's networking.service — we use systemd-networkd.
    # debootstrap pulls in ifupdown (Priority: important) whose
    # networking.service only configures loopback and races with networkd.
    chroot "$TARGET" systemctl disable networking.service 2>/dev/null || true
    chroot "$TARGET" systemctl mask networking.service 2>/dev/null || true

    # Enable systemd-networkd for network management.
    chroot "$TARGET" systemctl enable systemd-networkd 2>/dev/null || true
    chroot "$TARGET" systemctl enable systemd-resolved 2>/dev/null || true

    # Point resolv.conf at systemd-resolved's stub so DNS works.
    ln -sf /run/systemd/resolve/stub-resolv.conf "$TARGET/etc/resolv.conf"

    # Reduce first-boot delay: default wait-online blocks until ALL interfaces
    # are configured, which stalls 90+ seconds if any NIC has no cable.
    # Override to wait for just one interface, with a 10-second timeout.
    mkdir -p "$TARGET/etc/systemd/system/systemd-networkd-wait-online.service.d"
    cat > "$TARGET/etc/systemd/system/systemd-networkd-wait-online.service.d/override.conf" << 'WAITCFG'
[Service]
ExecStart=
ExecStart=/usr/lib/systemd/systemd-networkd-wait-online --any --timeout=10
WAITCFG

    # Persistent NIC naming: bind each MAC address to a stable net0, net1, ...
    # name so that adding or removing hardware never renumbers existing NICs.
    mkdir -p "$TARGET/etc/systemd/network"
    local idx=0
    for dev in /sys/class/net/*; do
        local name=$(basename "$dev")
        [ "$name" = "lo" ] && continue
        local mac=$(cat "$dev/address" 2>/dev/null)
        [ -z "$mac" ] && continue
        cat > "$TARGET/etc/systemd/network/00-net${idx}.link" << LINK
[Match]
MACAddress=$mac

[Link]
Name=net${idx}
LINK
        echo "  Pinned $name ($mac) -> net${idx}"
        idx=$((idx + 1))
    done

    # DHCP on all Ethernet interfaces. Match on Type=ether so DHCP works
    # even if the .link rename hasn't taken effect yet (e.g. initramfs
    # named the interface before udev processed our .link files).
    cat > "$TARGET/etc/systemd/network/10-dhcp.network" << NETCFG
[Match]
Type=ether

[Network]
DHCP=yes
IPv6AcceptRA=yes
NETCFG

    # MDADM config (if RAID).
    if [ "$USE_RAID" = "1" ]; then
        mkdir -p "$TARGET/etc/mdadm"
        # Write array definitions from the running arrays.
        echo "DEVICE partitions" > "$TARGET/etc/mdadm/mdadm.conf"
        mdadm --detail --scan >> "$TARGET/etc/mdadm/mdadm.conf" 2>/dev/null || true
        echo "  mdadm.conf:"
        cat "$TARGET/etc/mdadm/mdadm.conf"

        # Ensure initramfs includes mdadm for RAID assembly at boot.
        mkdir -p "$TARGET/etc/initramfs-tools/conf.d"
        echo "BOOT_DEGRADED=true" > "$TARGET/etc/initramfs-tools/conf.d/mdadm"

        # Force LVM to only scan md devices, not raw RAID member partitions.
        # Without this, LVM finds the PV on a single member and mounts a
        # degraded volume without assembling the RAID first.
        mkdir -p "$TARGET/etc/lvm"
        if [ -f "$TARGET/etc/lvm/lvm.conf" ]; then
            sed -i 's|# *global_filter *=.*|global_filter = [ "a|/dev/md.*|", "r|/dev/sd.*|", "r|/dev/nvme.*|" ]|' \
                "$TARGET/etc/lvm/lvm.conf" 2>/dev/null || true
        fi
        # Also set the filter in a drop-in for reliability.
        mkdir -p "$TARGET/etc/lvm/lvmlocal.conf.d"
        cat > "$TARGET/etc/lvm/lvmlocal.conf.d/smoothnas-raid.conf" << 'LVMCFG'
devices {
    global_filter = [ "a|/dev/md.*|", "r|/dev/sd.*|", "r|/dev/nvme.*|" ]
}
LVMCFG

        echo "  Rebuilding initramfs with RAID support..."
        chroot "$TARGET" update-initramfs -u 2>&1 || true
    else
        # Single-disk: still rebuild initramfs so it includes LVM tools
        # and the correct fstab/root device. The kernel's postinst was
        # stubbed during install so update-initramfs never ran.
        echo "  Rebuilding initramfs with LVM support..."
        chroot "$TARGET" update-initramfs -u 2>&1 || true
    fi

    # GRUB config: preload modules needed for RAID+LVM boot.
    cat >> "$TARGET/etc/default/grub" << 'GRUBCFG'

# SmoothNAS: preload modules for mdraid + LVM root
GRUB_PRELOAD_MODULES="part_gpt part_msdos mdraid1x lvm ext2"
GRUB_DISABLE_OS_PROBER=true
GRUB_TERMINAL="console serial"
GRUB_SERIAL_COMMAND="serial --speed=115200"
GRUB_CMDLINE_LINUX="console=ttyS0,115200n8 console=tty0 transparent_hugepage=madvise numa_balancing=disable"
GRUBCFG

    # Persistent kernel tuning for NAS workloads. Applied at boot via
    # sysctl.d — earlier than tierd starts and guaranteed even if tierd
    # is not running. tierd's ApplyNetworkTuning() acts as a runtime
    # safety net for upgrades on machines that predate this file.
    cat > "$TARGET/etc/sysctl.d/99-smoothnas.conf" << 'SYSCTL'
# SmoothNAS: NAS performance tuning — do not edit, managed by installer.

# TCP socket buffer ceilings: auto-tune up to 128 MB for fast NICs.
net.core.rmem_max = 134217728
net.core.wmem_max = 134217728
net.ipv4.tcp_rmem = 4096 87380 134217728
net.ipv4.tcp_wmem = 4096 65536 134217728

# NIC RX queue depth.
net.core.netdev_max_backlog = 5000

# BBR congestion control: far better than CUBIC for high-bandwidth LAN.
# Requires tcp_bbr module (loaded via /etc/modules).
net.core.default_qdisc = fq
net.ipv4.tcp_congestion_control = bbr

# Dirty page flush thresholds.
vm.dirty_background_ratio = 5
vm.dirty_ratio = 20

# VFS metadata cache: keep dentry/inode cache in RAM longer.
# Default 100 reclaims aggressively; 50 suits a NAS where the same
# paths are stat'd repeatedly by every connected client.
vm.vfs_cache_pressure = 50
SYSCTL

    # I/O scheduler udev rules: no scheduler for NVMe (let the drive
    # queue handle ordering), BFQ for rotational disks and md arrays
    # (budget fair queueing handles mixed sequential/random well).
    cat > "$TARGET/etc/udev/rules.d/60-smoothnas-iosched.rules" << 'UDEV'
# SmoothNAS: I/O scheduler selection — do not edit, managed by installer.
ACTION=="add|change", KERNEL=="nvme*", ATTR{queue/scheduler}="none"
ACTION=="add|change", KERNEL=="sd[a-z]*", ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="none"
ACTION=="add|change", KERNEL=="sd[a-z]*", ATTR{queue/rotational}=="1", ATTR{queue/scheduler}="bfq"
ACTION=="add|change", KERNEL=="md*", ATTR{queue/scheduler}="bfq"
UDEV

    # Base nftables rules.
    cat > "$TARGET/etc/nftables.conf" << 'NFT'
#!/usr/sbin/nft -f
flush ruleset
table inet filter {
    chain input {
        type filter hook input priority 0; policy drop;
        ct state established,related accept
        iif lo accept
        meta l4proto icmp accept
        meta l4proto icmpv6 accept
        tcp dport 22 accept comment "SSH"
        tcp dport 80 accept comment "HTTP redirect"
        tcp dport 443 accept comment "HTTPS"
    }
    chain forward {
        type filter hook forward priority 0; policy drop;
    }
    chain output {
        type filter hook output priority 0; policy accept;
    }
}
NFT
    chroot "$TARGET" systemctl enable nftables 2>/dev/null || true

    # --- Install tierd (storage management daemon) ---
    if [ -f /smoothnas/tierd ]; then
        echo "  Installing tierd..."
        install -m 755 /smoothnas/tierd "$TARGET/usr/local/bin/tierd"

        cat > "$TARGET/etc/systemd/system/tierd.service" << 'UNIT'
[Unit]
Description=SmoothNAS Storage Management Daemon
After=network-online.target smoothnas-firstboot.service
Wants=network-online.target

[Service]
Type=simple
ExecStartPre=+/bin/sh -c '[ -f /etc/pam.d/tierd ] || printf "auth [success=1 default=ignore] pam_unix.so nullok\nauth requisite pam_deny.so\nauth required pam_permit.so\naccount [success=1 new_authtok_reqd=done default=ignore] pam_unix.so\naccount requisite pam_deny.so\naccount required pam_permit.so\n" > /etc/pam.d/tierd'
ExecStart=/usr/local/bin/tierd
Environment=TIERD_ADDR=127.0.0.1:8420
Environment=TIERD_DB=/var/lib/tierd/tierd.db
Environment=HOME=/root
Environment=USER=root
Environment=LOGNAME=root
Restart=on-failure
RestartSec=5
PrivateTmp=true
NoNewPrivileges=false

[Install]
WantedBy=multi-user.target
UNIT
        chroot "$TARGET" systemctl enable tierd.service 2>/dev/null || true
    else
        echo "  WARNING: /smoothnas/tierd not found, skipping daemon install"
    fi

    # --- Install tierd-ui (web frontend) ---
    if [ -d /smoothnas/tierd-ui ]; then
        echo "  Installing tierd-ui..."
        mkdir -p "$TARGET/usr/share/tierd-ui"
        cp -r /smoothnas/tierd-ui/* "$TARGET/usr/share/tierd-ui/"
    else
        echo "  WARNING: /smoothnas/tierd-ui not found, skipping frontend install"
    fi

    # --- Configure nginx as reverse proxy ---
    cat > "$TARGET/etc/nginx/sites-available/tierd" << 'NGINX'
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name _;

    client_max_body_size 512m;

    ssl_certificate     /etc/tierd/tls/cert.pem;
    ssl_certificate_key /etc/tierd/tls/key.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    root /usr/share/tierd-ui;
    index index.html;

    location /api/ {
        proxy_pass http://127.0.0.1:8420;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name _;
    return 301 https://$host$request_uri;
}
NGINX
    chroot "$TARGET" ln -sf /etc/nginx/sites-available/tierd /etc/nginx/sites-enabled/tierd
    chroot "$TARGET" rm -f /etc/nginx/sites-enabled/default
    chroot "$TARGET" systemctl enable nginx.service 2>/dev/null || true

    # --- Install firstboot script ---
    if [ -f /smoothnas-firstboot ]; then
        install -m 755 /smoothnas-firstboot "$TARGET/usr/local/bin/smoothnas-firstboot"

        cat > "$TARGET/etc/systemd/system/smoothnas-firstboot.service" << 'UNIT'
[Unit]
Description=SmoothNAS First Boot Setup
After=network-online.target
ConditionPathExists=!/var/lib/tierd/.firstboot-done

[Service]
Type=oneshot
ExecStart=/usr/local/bin/smoothnas-firstboot
RemainAfterExit=true

[Install]
WantedBy=multi-user.target
UNIT
        chroot "$TARGET" systemctl enable smoothnas-firstboot.service 2>/dev/null || true
    fi

    echo "  System configured."
}

# ============================================================
# 8. Install GRUB
# ============================================================

install_grub() {
    msg "Installing GRUB bootloader"

    local uefi_ok=0
    local bios_ok=0

    # UEFI: preferred when the system booted via EFI.
    if [ -d /sys/firmware/efi ]; then
        if chroot "$TARGET" dpkg -l grub-efi-amd64 2>/dev/null | grep -q '^ii'; then
            echo "  Installing GRUB (UEFI)..."
            chroot "$TARGET" grub-install --target=x86_64-efi \
                --efi-directory=/boot/efi --bootloader-id=smoothnas \
                --recheck --no-nvram 2>&1 && uefi_ok=1
            if [ "$uefi_ok" = "0" ]; then
                echo "  WARNING: UEFI GRUB install failed"
            fi
            # Also install to the removable/fallback path. This handles
            # firmware without NVRAM entries (VMs, fresh installs).
            echo "  Installing GRUB (UEFI removable)..."
            chroot "$TARGET" grub-install --target=x86_64-efi \
                --efi-directory=/boot/efi \
                --recheck --no-nvram --removable 2>&1 || \
                echo "  WARNING: UEFI removable GRUB install failed"
        fi
    fi

    # BIOS fallback: install to every selected disk for RAID resilience.
    # Always attempt if grub-pc-bin is installed, even on UEFI systems,
    # so the disk can boot on legacy hardware too.
    if chroot "$TARGET" dpkg -l grub-pc-bin 2>/dev/null | grep -q '^ii'; then
        for disk in $SELECTED_DISKS; do
            echo "  Installing GRUB (BIOS) to $disk..."
            chroot "$TARGET" grub-install --target=i386-pc \
                "$disk" 2>&1 && bios_ok=1 || \
                echo "  WARNING: BIOS GRUB install to $disk failed"
        done
    fi

    if [ "$uefi_ok" = "0" ] && [ "$bios_ok" = "0" ]; then
        echo "  ERROR: No bootloader was installed successfully!"
    fi

    chroot "$TARGET" update-grub 2>&1 || echo "  WARNING: update-grub failed"
    echo "  GRUB installed."
}

# ============================================================
# 9. Completion
# ============================================================

finish() {
    msg "Installation complete"

    # Unmount everything.
    umount "$TARGET/dev/pts" 2>/dev/null || true
    umount "$TARGET/dev" 2>/dev/null || true
    umount "$TARGET/proc" 2>/dev/null || true
    umount "$TARGET/sys" 2>/dev/null || true
    umount "$TARGET/boot/efi" 2>/dev/null || true
    umount "$TARGET/boot" 2>/dev/null || true
    umount "$TARGET" 2>/dev/null || true

    local ip_addr=$(ip -4 addr show scope global | sed -n 's/.*inet \([0-9.]*\).*/\1/p' | head -1)

    echo ""
    echo "  ========================================="
    echo "   SmoothNAS Installation Complete"
    echo "  ========================================="
    echo ""
    echo "   Web UI:   https://${ip_addr:-<your-ip>}"
    echo "   Username: admin"
    echo ""
    echo "   Remove the installation media and"
    echo "   press Enter to reboot."
    echo ""
    read dummy < /dev/console

    echo "Rebooting..."
    sync
    sleep 1
    # The installer runs as PID 1 in the d-i initrd, so normal reboot
    # commands may not work. Use SysRq to force an immediate reboot.
    echo 1 > /proc/sys/kernel/sysrq 2>/dev/null || true
    echo b > /proc/sysrq-trigger 2>/dev/null || true
    # Fallbacks if SysRq didn't work.
    reboot -f 2>/dev/null || true
    sleep 2
    # Last resort: signal init (ourselves) to reboot.
    kill -INT 1 2>/dev/null || true
}

